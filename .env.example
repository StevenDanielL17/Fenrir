# Fenrir Environment Variables
# Copy to .env and fill in values

# Deployer wallet private key (Foundry deployment)
PRIVATE_KEY=

# EVM-compatible Westend RPC
WESTEND_EVM_RPC=https://westend-asset-hub-eth-rpc.polkadot.io

# WebSocket Westend RPC
WESTEND_WS_RPC=wss://westend-rpc.polkadot.io

# Optional — increases Polkassembly rate limits
POLKASSEMBLY_API_KEY=

# Deployed contract addresses (set after deployment)
INFERENCE_CONTRACT=
VITE_SCORER_ADDRESS=
VITE_INFERENCE_ADDRESS=
VITE_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
VITE_CHAIN_ID=420420421
